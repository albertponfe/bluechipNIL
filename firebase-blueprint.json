{
  "entities": {
    "Athlete": {
      "title": "Athlete Profile",
      "description": "Profile information for a college athlete.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "photoUrl": { "type": "string" },
        "instagram": { "type": "string" },
        "twitter": { "type": "string" },
        "tiktok": { "type": "string" },
        "sport": { "type": "string" },
        "university": { "type": "string" },
        "year": { "type": "string" },
        "position": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "createdAt", "sport", "university", "year"]
    },
    "Brand": {
      "title": "Brand Profile",
      "description": "Profile information for a brand or business.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "photoUrl": { "type": "string" },
        "website": { "type": "string" },
        "industry": { "type": "string" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Deal": {
      "title": "NIL Deal",
      "description": "A sponsorship or NIL deal between an athlete and a brand.",
      "type": "object",
      "properties": {
        "athleteId": { "type": "string" },
        "brandId": { "type": "string" },
        "brandName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["athleteId", "brandId", "brandName", "title", "description", "amount", "status", "createdAt"]
    },
    "ContractAnalysis": {
      "title": "Contract Analysis",
      "description": "AI analysis of a legal document for an athlete.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "contractText": { "type": "string" },
        "analysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" }
      },
      "required": ["uid", "contractText", "analysis", "createdAt"]
    }
  },
  "firestore": {
    "athletes/{athleteId}": {
      "schema": "Athlete",
      "description": "Collection of athlete profiles."
    },
    "brands/{brandId}": {
      "schema": "Brand",
      "description": "Collection of brand profiles."
    },
    "deals/{dealId}": {
      "schema": "Deal",
      "description": "Collection of NIL deals."
    },
    "analyses/{analysisId}": {
      "schema": "ContractAnalysis",
      "description": "Collection of AI contract analyses."
    }
  }
}
