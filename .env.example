# NOTE: GEMINI_API_KEY, OPENAI_API_KEY, and RESEND_API_KEY are NOT set here.
# They used to be (or would be) client env vars (insecure — shipped in the browser bundle).
# All such calls go through Supabase Edge Functions that hold the real
# keys server-side. Set them as Supabase secrets instead, e.g.:
#   npx supabase secrets set GEMINI_API_KEY=your-key OPENAI_API_KEY=your-key
#   npx supabase secrets set RESEND_API_KEY=re_xxxxxxxxx
# See supabase/functions/gemini-proxy, supabase/functions/generate-image,
# and supabase/functions/send-email.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL / SUPABASE_ANON_KEY: from your Supabase project's
# Settings > API page. The anon key is safe to expose in client code —
# Row Level Security policies (see supabase/migrations) do the real enforcement.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_ANON_PUBLIC_KEY"
